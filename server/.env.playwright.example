# Playwright 专用服务端环境变量
# 使用独立数据库和端口，避免污染本地开发环境

PORT=4100
PLAYWRIGHT_CLIENT_PORT=4173
CLIENT_ORIGIN="http://127.0.0.1:4173"

DATABASE_URL="postgresql://username:password@localhost:5432/helpdesk_playwright?schema=public"

BETTER_AUTH_URL="http://127.0.0.1:4100"
BETTER_AUTH_SECRET="replace-with-a-random-secret-at-least-32-characters"
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="qwerdf66"
