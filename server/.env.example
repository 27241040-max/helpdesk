# -------------------------------------------------------------
# AI Helpdesk Server - Environment Variables Example
# 请复制此文件并重命名为 .env，然后将下面的假数据替换为你真实的账号凭据
# 警告: 真正的 .env 包含机密信息，已经被 .gitignore 屏蔽，不要提交它！
# -------------------------------------------------------------

# --- Server Core (核心服务器) ---
# Exprses 后端运行的端口号
PORT=4000
CLIENT_ORIGIN="http://localhost:5173"

# --- Database (数据库) ---
# 请将 username, password 替换为你的本地或云端 Postgres 库的真实配置，最后的 helpdesk 是库名
DATABASE_URL="postgresql://username:password@localhost:5432/helpdesk?schema=public"

# --- Authentication (身份验证) ---
# Better Auth 使用的服务端 URL 和加密密钥
BETTER_AUTH_URL="http://localhost:4000"
BETTER_AUTH_SECRET="replace-with-a-random-secret-at-least-32-characters"
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="password123"

# --- AI Integration (人工智能引擎) ---
# 我们需要用来对客户邮件进行分类、摘要及问答回复的大语言模型 API 密钥
OPENAI_API_KEY="sk-proj-xxxxxxxxxxxxxxxxxxxxxxxx"

# --- Incoming Mail Configuration (IMAP 收取) ---
# 系统用于持续轮询读取发给该邮箱的求助邮件并转换为工单
IMAP_HOST="imap.gmail.com"
IMAP_PORT=993
IMAP_USER="support@yourcompany.com"
IMAP_PASSWORD="your_app_specific_password"

# --- Outgoing Mail Configuration (SMTP 发送) ---
# 用于 AI 代发或专员（代理）向客户发送的正式邮件回复网关
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="support@yourcompany.com"
SMTP_PASSWORD="your_app_specific_password"
